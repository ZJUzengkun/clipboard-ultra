{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clipboard-ultra",
  "version": "0.6.8",
  "identifier": "com.zk.clipboard-ultra",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clipboard Ultra",
        "width": 1920,
        "height": 360,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "focus": false
      },
      {
        "label": "settings",
        "title": "偏好设置",
        "url": "settings.html",
        "width": 580,
        "height": 620,
        "minWidth": 480,
        "minHeight": 400,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
