{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clipboard-ultra",
  "version": "0.8.9",
  "identifier": "com.zk.clipboard-ultra",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Clipboard Ultra",
        "width": 1920,
        "height": 360,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "focus": false
      },
      {
        "label": "settings",
        "title": "偏好设置",
        "url": "settings.html",
        "width": 580,
        "height": 620,
        "minWidth": 480,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "$APPDATA/**",
          "$HOME/**",
          "C:/**",
          "D:/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVENEIzRUY4QkZCMDEwRUUKUldUdUVMQy8rRDVMN1ZyZVF3S09Ka2NmYTRjclBheVF2RXcveWozc3FaSHZDZ0xqa0IxZnA0VUsK",
      "endpoints": [
        "https://github.com/ZJUzengkun/clipboard-ultra/releases/latest/download/latest.json"
      ]
    }
  }
}
